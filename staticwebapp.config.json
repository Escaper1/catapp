{
  "routes": [
    {
      "route": "/",
      "rewrite": "/index.html"
    },
    {
      "route": "/cat",
      "rewrite": "/index.html"
    },
    {
      "route": "/assets/*",
      "headers": {
        "cache-control": "public, max-age=31536000"
      }
    }
  ],
  "mimeTypes": {
    ".json": "text/json",
    ".woff": "font/woff",
    ".woff2": "font/woff2"
  },
  "globalHeaders": {
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }

  
}
